PORT=3000
# Bỏ qua kiểm tra DATABASE_URL/JWT_SECRET lúc khởi động (chỉ dùng tạm, không dùng production)
# SKIP_ENV_VALIDATION=1

# Local/dev (MySQL chuẩn, không SSL)
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/media_club"

# Production (ví dụ Aiven MySQL): copy "Service URI" từ trang Overview sau khi bật mật khẩu.
# Giữ nguyên query ?ssl-mode=REQUIRED. Nếu mật khẩu có ký tự đặc biệt, URL-encode (vd. @ → %40).
# Trên Aiven: bật IP cho máy/dev server trong service (IP filter / allowlist) trước khi kết nối.
# DATABASE_URL="mysql://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED"

JWT_SECRET="change-me-min-32-characters-random-hex"
# Access JWT: ngắn hạn (cũ: JWT_EXPIRES_IN dùng fallback)
JWT_ACCESS_EXPIRES="15m"
# Refresh token: số ngày lưu trong bảng refresh_tokens
REFRESH_DAYS=7
# production: bật để thêm flag Secure lên cookie
COOKIE_SECURE=false
# Khi frontend và API khác subdomain (vd. Render): COOKIE_SECURE=true và COOKIE_SAMESITE=none
# COOKIE_SAMESITE=none
# nhiều origin cách bởi dấu phẩy, hoặc * (dev)
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
# Tên cookie (mặc định: med_access, med_refresh)
# AUTH_ACCESS_COOKIE=med_access
# AUTH_REFRESH_COOKIE=med_refresh

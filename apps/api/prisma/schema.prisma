  actual_end_at               DateTime?                     @db.DateTime(6)
  status                      events_status                 @default(draft)
  requires_approval           Boolean                       @default(true)
  default_cancel_minutes      Int?                          @db.UnsignedInt
  created_by                  BigInt                        @db.UnsignedBigInt
  created_at                  DateTime                      @default(now()) @db.Timestamp(6)
  updated_at                  DateTime                      @default(now()) @db.Timestamp(6)
  absence_requests            absence_requests[]
  event_checkins              event_checkins[]
  event_managers              event_managers[]
  event_meetings              event_meetings[]
  event_registrations         event_registrations[]

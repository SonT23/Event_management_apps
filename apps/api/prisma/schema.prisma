generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model absence_requests {
  id                                       BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  event_id                                 BigInt                  @db.UnsignedBigInt
  user_id                                  BigInt                  @db.UnsignedBigInt
  reason                                   String                  @db.Text
  status                                   absence_requests_status @default(pending)
  decided_by                               BigInt?                 @db.UnsignedBigInt
  decided_at                               DateTime?               @db.DateTime(6)
  created_at                               DateTime                @default(now()) @db.Timestamp(6)
  users_absence_requests_decided_byTousers users?                  @relation("absence_requests_decided_byTousers", fields: [decided_by], references: [id], onUpdate: NoAction, map: "fk_absence_dec")
  events                                   events                  @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_absence_event")
  users_absence_requests_user_idTousers    users                   @relation("absence_requests_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_absence_user")

  @@index([decided_by], map: "fk_absence_dec")
  @@index([user_id], map: "fk_absence_user")
  @@index([event_id, user_id], map: "ix_absence_event")
}

model departments {
  id                Int               @id @default(autoincrement()) @db.UnsignedSmallInt
  code              String            @unique(map: "ux_departments_code") @db.VarChar(64)
  name              String            @db.VarChar(128)
  parent_id         Int?              @db.UnsignedSmallInt
  sort_order        Int               @default(0) @db.SmallInt
  created_at        DateTime          @default(now()) @db.Timestamp(0)
  departments       departments?      @relation("departmentsTodepartments", fields: [parent_id], references: [id], onUpdate: NoAction, map: "fk_departments_parent")
  other_departments departments[]     @relation("departmentsTodepartments")
  members           members[]
  user_club_roles   user_club_roles[]

  @@index([parent_id], map: "ix_departments_parent")
}

model event_checkins {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  event_id            BigInt              @db.UnsignedBigInt
  registration_id     BigInt              @unique(map: "ux_checkin_reg") @db.UnsignedBigInt
  scanned_by          BigInt              @db.UnsignedBigInt
  scanned_at          DateTime            @db.DateTime(6)
  note                String?             @db.VarChar(255)
  users               users               @relation(fields: [scanned_by], references: [id], onUpdate: NoAction, map: "fk_checkin_by")
  events              events              @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_checkin_event")
  event_registrations event_registrations @relation(fields: [registration_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_checkin_reg")

  @@index([scanned_by], map: "fk_checkin_by")
  @@index([event_id], map: "ix_checkin_event")
}

model event_managers {
  id                                      BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  event_id                                BigInt   @db.UnsignedBigInt
  user_id                                 BigInt   @db.UnsignedBigInt
  assigned_by                             BigInt   @db.UnsignedBigInt
  assigned_at                             DateTime @default(now()) @db.Timestamp(0)
  users_event_managers_assigned_byTousers users    @relation("event_managers_assigned_byTousers", fields: [assigned_by], references: [id], onUpdate: NoAction, map: "fk_event_managers_assigned")
  events                                  events   @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_event_managers_event")
  users_event_managers_user_idTousers     users    @relation("event_managers_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_event_managers_user")

  @@unique([event_id, user_id], map: "ux_event_manager")
  @@index([assigned_by], map: "fk_event_managers_assigned")
  @@index([user_id], map: "ix_event_managers_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model event_meetings {
  id                  BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  event_id            BigInt                      @db.UnsignedBigInt
  title               String                      @db.VarChar(200)
  /// Lý do / nội dung trọng tâm buổi họp
  reason              String?                     @db.Text
  status              event_meetings_status       @default(scheduled)
  cancelled_at        DateTime?                   @db.DateTime(6)
  meeting_type        event_meetings_meeting_type @default(pre_event)
  start_at            DateTime                    @db.DateTime(6)
  /// Dự kiến kết thúc; nếu không kết sớm thì mốc này là thời điểm kết thúc chính thức
  end_at              DateTime                    @db.DateTime(6)
  /// Khi quản lý nhấn kết sớm; nếu null, kết thúc chính thức = end_at
  actual_end_at       DateTime?                   @db.DateTime(6)
  scan_open_at        DateTime?                   @db.DateTime(6)
  scan_close_at       DateTime?                   @db.DateTime(6)
  created_by          BigInt                      @db.UnsignedBigInt
  created_at          DateTime                    @default(now()) @db.Timestamp(6)
  users               users                       @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_meet_by")
  events              events                      @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_meet_event")
  meeting_attendances meeting_attendances[]
  penalty_events      penalty_events[]

  @@index([created_by], map: "fk_meet_by")
  @@index([event_id, start_at], map: "ix_meet_event")
  @@index([event_id, status], map: "ix_meet_event_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model event_registrations {
  id                                          BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  event_id                                    BigInt                     @db.UnsignedBigInt
  user_id                                     BigInt                     @db.UnsignedBigInt
  status                                      event_registrations_status @default(pending)
  qr_token_hash                               String                     @db.Char(64)
  qr_issued_at                                DateTime?                  @db.Timestamp(6)
  decided_by                                  BigInt?                    @db.UnsignedBigInt
  decided_at                                  DateTime?                  @db.DateTime(6)
  cancel_not_before                           DateTime?                  @db.DateTime(6)
  created_at                                  DateTime                   @default(now()) @db.Timestamp(6)
  updated_at                                  DateTime                   @default(now()) @db.Timestamp(6)
  event_checkins                              event_checkins?
  users_event_registrations_decided_byTousers users?                     @relation("event_registrations_decided_byTousers", fields: [decided_by], references: [id], onUpdate: NoAction, map: "fk_reg_decider")
  events                                      events                     @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reg_event")
  users_event_registrations_user_idTousers    users                      @relation("event_registrations_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reg_user")
  meeting_attendances                         meeting_attendances[]

  @@unique([event_id, user_id], map: "ux_reg_event_user")
  @@index([decided_by], map: "fk_reg_decider")
  @@index([event_id], map: "ix_reg_event")
  @@index([qr_token_hash], map: "ix_reg_qr")
  @@index([user_id], map: "ix_reg_user")
}

model event_subcommittee_members {
  id                                                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  subcommittee_id                                     BigInt              @db.UnsignedBigInt
  user_id                                             BigInt              @db.UnsignedBigInt
  assigned_by                                         BigInt              @db.UnsignedBigInt
  assigned_at                                         DateTime            @default(now()) @db.Timestamp(0)
  users_event_subcommittee_members_assigned_byTousers users               @relation("event_subcommittee_members_assigned_byTousers", fields: [assigned_by], references: [id], onUpdate: NoAction, map: "fk_subc_mem_by")
  event_subcommittees                                 event_subcommittees @relation(fields: [subcommittee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subc_mem_sub")
  users_event_subcommittee_members_user_idTousers     users               @relation("event_subcommittee_members_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subc_mem_user")

  @@unique([subcommittee_id, user_id], map: "ux_subc_user")
  @@index([assigned_by], map: "fk_subc_mem_by")
  @@index([user_id], map: "ix_subc_mem_user")
}

model event_subcommittees {
  id                         BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  event_id                   BigInt                       @db.UnsignedBigInt
  name                       String                       @db.VarChar(160)
  code                       String?                      @db.VarChar(64)
  /// null = không giới hạn
  max_members                Int?                         @db.UnsignedSmallInt
  created_by                 BigInt                       @db.UnsignedBigInt
  created_at                 DateTime                     @default(now()) @db.Timestamp(0)
  event_subcommittee_members event_subcommittee_members[]
  users                      users                        @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_subc_by")
  events                     events                       @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_subc_event")

  @@index([created_by], map: "fk_subc_by")
  @@index([event_id], map: "ix_subc_event")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.

  id                   BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  user_id              BigInt           @db.UnsignedBigInt
  token_hash           String           @unique(map: "ux_refresh_token_hash") @db.Char(64)
  family_id            String?          @db.Char(36)
  expires_at           DateTime
  revoked_at           DateTime?
  replaced_by_id       BigInt?          @db.UnsignedBigInt
  user_agent           String?          @db.VarChar(500)
  ip                   String?          @db.VarChar(45)
  created_at           DateTime         @default(now())
  refresh_tokens       refresh_tokens?  @relation("refresh_tokensTorefresh_tokens", fields: [replaced_by_id], references: [id], onUpdate: NoAction, map: "fk_refresh_replaced")
  other_refresh_tokens refresh_tokens[] @relation("refresh_tokensTorefresh_tokens")
  users                users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_refresh_user")

  @@index([replaced_by_id], map: "fk_refresh_replaced")
  @@index([expires_at], map: "ix_refresh_expires")
  @@index([user_id], map: "ix_refresh_user")
}

enum members_gender {
  male
  female
  other
  unspecified
}

enum event_meetings_meeting_type {
  pre_event
  in_event
}

enum event_meetings_status {
  scheduled
  cancelled
}

enum event_registrations_status {
  pending
  approved
  rejected
  cancelled
}

enum absence_requests_status {
  pending
  approved
  rejected
}

enum participation_cancellations_status {
  pending
  approved
  rejected
}

enum events_status {
  draft
  published
  ongoing
  ended
  cancelled
}

enum meeting_attendances_result {
  on_time
  late
  out_of_window
}

enum members_membership_status {
  active
  inactive
}

/// Cuộc họp nội bộ CLB (không gắn sự kiện): định kỳ, cuối năm, v.v.
enum club_meeting_kind {
  quarterly
  year_end
  board
  general
  other
  emergency
}

enum club_meeting_mandatory_scope {
  all_members
  club_leadership
  dept_heads_only
  selected_members
}

enum club_meeting_status {
  scheduled
  cancelled
}

model club_meetings {
  id                BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  title             String                       @db.VarChar(200)
  detail            String?                      @db.Text
  kind              club_meeting_kind            @default(general)
  mandatory_scope   club_meeting_mandatory_scope @default(all_members)
  start_at          DateTime                     @db.DateTime(6)
  end_at            DateTime                     @db.DateTime(6)
  status            club_meeting_status         @default(scheduled)
  cancelled_at      DateTime?                    @db.DateTime(6)
  created_by        BigInt                      @db.UnsignedBigInt
  created_at        DateTime                    @default(now()) @db.Timestamp(6)
  updated_at        DateTime                    @default(now()) @updatedAt @db.Timestamp(6)
  users              users                       @relation("club_meetings_created", fields: [created_by], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_club_meet_by")
  absence_requests  club_meeting_absence_requests[]
  invitees          club_meeting_invitees[]

  @@index([created_by], map: "fk_club_meet_by")
  @@index([start_at], map: "ix_club_meet_start")
  @@index([status], map: "ix_club_meet_status")
}

/// Hội viên được mời khi phạm vi = selected_members
model club_meeting_invitees {
  club_meeting_id BigInt        @db.UnsignedBigInt
  user_id         BigInt        @db.UnsignedBigInt
  club_meetings   club_meetings @relation(fields: [club_meeting_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cmi_meet")
  users           users         @relation("club_meeting_invited_users", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cmi_user")

  @@id([club_meeting_id, user_id])
  @@index([user_id], map: "ix_cmi_user")
}

model club_meeting_absence_requests {
  id                 BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  club_meeting_id    BigInt                @db.UnsignedBigInt
  user_id            BigInt                @db.UnsignedBigInt
  reason             String                @db.Text
  status             absence_requests_status @default(pending)
  decided_by         BigInt?               @db.UnsignedBigInt
  decided_at         DateTime?             @db.DateTime(6)
  created_at         DateTime              @default(now()) @db.Timestamp(6)
  club_meetings      club_meetings         @relation(fields: [club_meeting_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cmar_meet")
  users              users                 @relation("cm_absence_user", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cmar_user")
  decider            users?                @relation("cm_absence_dec", fields: [decided_by], references: [id], onUpdate: NoAction, map: "fk_cmar_dec")

  @@unique([club_meeting_id, user_id], map: "ux_cmar_meet_user")
  @@index([user_id], map: "ix_cmar_user")
  @@index([decided_by], map: "fk_cmar_dec")
}
